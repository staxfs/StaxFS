include "mdrequest.fbs";

namespace dfs.mdrequest;

table MDPathCommonRequest {
  uid: uint32;
  gid: uint32;
  op: MDOpType;
  path: string;
  mode: uint32; // only for mkdir and access
  newpath: string; // only for rename
  meta_num: int;
  last_seen_hlc: uint64;
}

root_type MDPathCommonRequest;
